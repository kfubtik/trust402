{
  "name": "trust402",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "src/server.js",
  "description": "Buyer-side trust and procurement agent for x402 resources.",
  "keywords": [
    "x402",
    "agent",
    "trust",
    "procurement",
    "micropayments"
  ],
  "scripts": {
    "dev": "node src/server.js",
    "dev:detached": "node scripts/start-detached.js",
    "doctor": "node scripts/doctor.js",
    "bazaar:indexing:check": "node scripts/check-bazaar-indexing.js",
    "bazaar:indexing:check:all": "node scripts/check-bazaar-indexing.js --all-resources",
    "marketplace:bundle": "node scripts/export-marketplace-bundle.js",
    "privacy:check": "node scripts/privacy-check.js",
    "release:check": "node scripts/release-check.js",
    "settlement:preflight": "node scripts/paid-smoke-preflight.js",
    "settlement:check": "node scripts/settlement-check.js",
    "start": "node src/server.js",
    "smoke": "node scripts/smoke.js",
    "smoke:x402": "node scripts/x402-smoke.js",
    "test": "node --test test",
    "verify": "node scripts/release-check.js"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@x402/core": "^2.12.0",
    "@x402/evm": "^2.12.0",
    "@x402/express": "^2.12.0",
    "@x402/extensions": "^2.12.0",
    "express": "^4.18.2"
