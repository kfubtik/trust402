{
  "brand": {
    "name": "Trust402",
    "direction": "x402 Radar",
    "tagline": "A live radar for x402 resources",
    "promise": "Track endpoints, compare prices, detect risk, and route safe payments through policy."
  },
  "colors": {
    "radarBlack": "#07110F",
    "deepField": "#0B1715",
    "panelGraphite": "#111E1B",
    "panelRaised": "#172622",
    "mist": "#F2F7F4",
    "softMist": "#D7E5DE",
    "mutedSteel": "#B4C8BE",
    "line": "#244039",
    "signalGreen": "#54F2A1",
    "cyanTrace": "#58D6FF",
    "magentaPing": "#F05BCE",
    "amberRisk": "#F5B84B",
    "redDeny": "#FF5C66"
  },
  "typography": {
    "ui": "Inter, Geist, Segoe UI, Arial, sans-serif",
    "mono": "JetBrains Mono, Geist Mono, Consolas, monospace",
    "headlineWeight": 720,
    "bodyWeight": 450,
    "letterSpacing": "0"
  },
  "radii": {
    "panel": "8px",
    "card": "8px",
    "chip": "999px",
    "button": "8px"
  },
  "spacing": {
    "sectionY": "88px",
    "containerMax": "1180px",
    "gridGap": "20px",
    "panelPadding": "20px"
  },
  "shadows": {
    "panel": "0 24px 70px rgba(0, 0, 0, 0.35)",
    "signal": "0 0 32px rgba(84, 242, 161, 0.18)",
    "cyan": "0 0 28px rgba(88, 214, 255, 0.16)"
  },
  "components": {
    "radarNode": {
      "size": "10px",
      "activeRing": "2px solid rgba(84, 242, 161, 0.4)",
      "blockedColor": "#FF5C66",
      "reviewColor": "#F5B84B"
    },
    "resourceCard": {
      "background": "#111E1B",
      "border": "1px solid #244039",
      "radius": "8px"
    },
    "policyGate": {
      "allowed": "#54F2A1",
      "review": "#F5B84B",
      "blocked": "#FF5C66"
    },
    "receiptRow": {
      "background": "rgba(242, 247, 244, 0.04)",
      "border": "1px solid rgba(215, 229, 222, 0.10)"
    }
  }
}
