HOST=127.0.0.1
PORT=4032
PUBLIC_BASE_URL=http://127.0.0.1:4032

# dry-run is the only supported MVP mode.
TRUST402_MODE=dry-run
TRUST402_REAL_SETTLEMENT_ENABLED=false
TRUST402_SUCCESSFUL_SETTLEMENT_OBSERVED=false
TRUST402_PAID_SMOKE_APPROVED=false
TRUST402_PAID_SMOKE_MAX_USD=0
TRUST402_PAID_SMOKE_RESOURCE_ID=trust.score_resource
TRUST402_OPERATOR_API_KEY=
TRUST402_EMERGENCY_STOP=false

# demo: paid resources respond normally.
# mock: paid resources return HTTP 402 until PAYMENT-SIGNATURE is supplied.
# real: reserved for future facilitator-backed settlement.
TRUST402_PAYWALL_MODE=demo

# Public payment metadata for mock challenges and future x402 integration.
X402_NETWORK=eip155:8453
X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PAY_TO=0x0000000000000000000000000000000000000000

# CDP facilitator values for future real settlement.
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Only needed later if Trust402 becomes a buyer that signs/spends.
CDP_WALLET_SECRET=
LIVE_SPEND_ENABLED=false
LIVE_PAYMENT_PROVIDER=disabled
LIVE_PAYMENT_ADAPTER_URL=
LIVE_MAX_PER_CALL_USD=0.05
LIVE_MAX_PER_JOB_USD=0.25
LIVE_DAILY_LIMIT_USD=2
LIVE_APPROVAL_THRESHOLD_USD=0
LIVE_ALLOWED_REGISTRIES=
LIVE_ENDPOINT_DENYLIST=
LIVE_RECEIPT_LOG_MODE=response-only

# AgentCash auto-refill is reserved for a later approved policy.
# Keep disabled until provider, threshold, amount, cap, audit log, and stop rules are approved.
AGENTCASH_WALLET_BINDING_REQUIRED=true
AGENTCASH_NETWORK=base
AGENTCASH_AUTO_REFILL_APPROVED=false
AGENTCASH_AUTO_REFILL_ENABLED=false
AGENTCASH_AUTO_REFILL_PROVIDER=
AGENTCASH_AUTO_REFILL_ADAPTER_URL=
AGENTCASH_AUTO_REFILL_THRESHOLD_USD=0.50
AGENTCASH_AUTO_REFILL_AMOUNT_USD=1.00
AGENTCASH_AUTO_REFILL_DAILY_CAP_USD=2.00

# Proof402 preview/probe target. Live paid delegation stays disabled in the MVP.
PROOF402_BASE_URL=https://proof402.vercel.app
# disabled: request preview only; probe: unpaid health/402 probe; live: blocked until policy approval.
PROOF402_DELEGATION_MODE=disabled
PROOF402_MAX_SPEND_USD=0

# Completion evidence flags. These are public-safe evidence pointers, not secrets.
# Keep false/empty until the corresponding production evidence exists.
TRUST402_GIT_AUTO_DEPLOY_VERIFIED=false
TRUST402_GIT_AUTO_DEPLOY_EVIDENCE_URL=
TRUST402_GIT_AUTO_DEPLOY_COMMIT_SHA=
TRUST402_EXTERNAL_DIRECTORY_STATUS=not-visible-yet
TRUST402_EXTERNAL_DIRECTORY_EVIDENCE_URL=
TRUST402_EXTERNAL_DIRECTORY_NAME=
TRUST402_LIVE_PROCUREMENT_SMOKE_OBSERVED=false
TRUST402_LIVE_PROCUREMENT_EVIDENCE_REF=
TRUST402_PROOF402_PAID_SMOKE_OBSERVED=false
TRUST402_PROOF402_EVIDENCE_REF=
TRUST402_AGENTCASH_AUTO_REFILL_EVIDENCE_OBSERVED=false
TRUST402_AGENTCASH_AUTO_REFILL_EVIDENCE_REF=
TRUST402_AUTONOMOUS_JOB_SMOKE_OBSERVED=false
TRUST402_AUTONOMOUS_JOB_EVIDENCE_REF=
TRUST402_FINAL_VERIFICATION_OBSERVED=false
TRUST402_FINAL_VERIFICATION_EVIDENCE_REF=
